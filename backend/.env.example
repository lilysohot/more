# ============================================
# 小财大用 - 环境配置示例
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ============================================
# 🔐 必需配置（生产环境必须设置）
# ============================================

# 数据库配置（必需）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database

# JWT 密钥（必需）- 使用以下命令生成安全的密钥:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# API Key 加密密钥（必需）- 使用以下命令生成32字节密钥:
# python -c "import secrets; print(secrets.token_urlsafe(32) + '!!!')"
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!!

# 默认 LLM API Key（可选但推荐）
# 用户不配置自己的 API 时使用此默认 Key
DEFAULT_LLM_API_KEY=your-llm-api-key

# ============================================
# 🔧 可选配置（可根据需要修改）
# ============================================

# Redis 配置
REDIS_URL=redis://localhost:6379

# JWT 算法
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30

# CORS 配置
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# API 配置限制
MAX_API_CONFIGS_PER_USER=10

# 调试模式（生产环境务必设为 false）
DEBUG=false

# 默认 LLM 模型配置
DEFAULT_LLM_PROVIDER=dashscope
DEFAULT_LLM_MODEL=qwen-turbo
